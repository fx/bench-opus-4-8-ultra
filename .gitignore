# Build output (embedded into the prod binary; regenerated by the Vite build).
# The committed web/dist/index.html placeholder is force-kept below so the
# embed package compiles on a clean checkout.
/web/dist/*
!/web/dist/index.html

# Dependencies
node_modules/

# air live-reload temp build dir
/tmp/

# Coverage artifacts
coverage.out
coverage/
*.lcov

# TypeScript incremental build info
*.tsbuildinfo

# Compiled Go binary (if built at repo root)
/slop-simulator

# Editor / OS noise
.DS_Store
*.local
